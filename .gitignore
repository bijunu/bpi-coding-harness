# Pi local state — ignore everything except tracked config
.pi/*
!.pi/settings.json

# Trace data — exclude by default, opt-in specific samples
traces/*
!traces/.gitkeep
!traces/sample/

# Node
node_modules/
*.log

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editor
.vscode/
.idea/
.DS_Store

# Secrets (paranoia)
.env
*.key
secrets.*
